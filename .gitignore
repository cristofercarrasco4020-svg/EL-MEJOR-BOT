# --- SEGURIDAD Y SESIONES ---
sesion_bot/*
!sesion_bot/.gitkeep

sesiones_subbots/*
!sesiones_subbots/.gitkeep

sockets/*
!sockets/.gitkeep

# --- CONFIGURACIÓN ---
# Ignorar bases de datos (archivos JSON) para no subir tus datos privados
config/**/*.json

# PERO permitir archivos de código necesarios
!config/print.js
!config/UploadFile.js

# Mantener las carpetas visibles en el repositorio
!config/.gitkeep
!config/database/.gitkeep

# --- OTROS ---
node_modules/
*.log
.env
