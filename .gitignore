# --- SEGURIDAD Y SESIONES ---
# Nota: No ponemos config.js aquí, así que Git lo subirá automáticamente.

# Ignorar contenido de carpetas críticas
sesion_bot/*
!sesion_bot/.gitkeep

sesiones_subbots/*
!sesiones_subbots/.gitkeep

sockets/*
!sockets/.gitkeep

# Ignorar la carpeta config completa (todo su contenido)
config/

# --- OTROS ---
node_modules/
*.log
.env

